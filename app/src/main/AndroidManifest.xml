<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        ════════════════════════════════════════════════════════
         PERMISSIONS
        ════════════════════════════════════════════════════════
    -->

    <!--
        UsageStatsManager 접근 권한.
        일반 권한 요청 불가 → 앱 내부에서 Settings.ACTION_USAGE_ACCESS_SETTINGS 인텐트로
        사용자를 설정 화면으로 안내해야 함.
    -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- 기기 재부팅 후 추적 서비스 재시작 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- 포그라운드 서비스 실행 (API 28+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!--
        API 34(Android 14) 필수: foregroundServiceType 을 명시해야 함.
        UsageStats 폴링은 'dataSync' 타입으로 분류.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- WorkManager 내부 사용 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- 알림 권한 (Android 13, API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        정확한 알람 (목표 초과 시점 즉시 트리거).
        API 31+ : SCHEDULE_EXACT_ALARM 또는 USE_EXACT_ALARM 필요.
        USE_EXACT_ALARM 은 시계·달력 앱 전용이므로 SCHEDULE_EXACT_ALARM 사용.
    -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!--
        ════════════════════════════════════════════════════════
         APPLICATION
        ════════════════════════════════════════════════════════
    -->
    <application
        android:name=".DopamineCatApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DopamineCat"
        tools:targetApi="34">

        <!-- ── Main Activity ──────────────────────────────────────────── -->
        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.DopamineCat.SplashScreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            ── UsageTracking ForegroundService ───────────────────────────
            실시간 스크린타임 감시 담당.
            foregroundServiceType = dataSync (API 34 필수 선언).
        -->
        <service
            android:name=".data.service.UsageTrackingService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!--
            ── BootReceiver ──────────────────────────────────────────────
            기기 재부팅 및 앱 업데이트 후 서비스/WorkManager 재등록.
        -->
        <receiver
            android:name=".data.receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!--
            ── CatWidgetReceiver (Glance) ────────────────────────────────
            GlanceAppWidgetReceiver 를 상속하여 Compose 로 위젯 렌더링.
            cat_widget_info.xml 에서 위젯 크기·업데이트 주기 선언.
        -->
        <receiver
            android:name=".presentation.widget.CatWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/cat_widget_info" />
        </receiver>

        <!--
            ── WorkManager Custom Initializer ────────────────────────────
            Hilt 와 통합하기 위해 기본 자동 초기화를 제거하고
            HiltWorkerFactory 를 DopamineCatApplication 에서 수동 등록.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
