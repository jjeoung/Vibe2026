<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        ════════════════════════════════════════════════════════
         PERMISSIONS
        ════════════════════════════════════════════════════════
    -->

    <!--
        UsageStatsManager 접근 권한.
        일반 런타임 요청 불가 → UI 에서 Settings.ACTION_USAGE_ACCESS_SETTINGS 로 유도.
    -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- 기기 재부팅 후 BootReceiver 가 서비스와 Worker 를 재시작하기 위해 필요 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- API 28+: 포그라운드 서비스 실행 선언 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!--
        API 34(Android 14) 필수: foregroundServiceType 을 코드와 Manifest 모두에 선언해야 함.
        UsageStats 폴링 서비스는 dataSync 타입으로 분류.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- WorkManager 내부 WakeLock 사용 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- 알림 권한 (Android 13, API 33+) — 목표 초과·보상 알림에 필요 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        목표 초과 시점을 정확히 감지하기 위한 알람 권한.
        API 31+: SCHEDULE_EXACT_ALARM 또는 USE_EXACT_ALARM 필요.
        USE_EXACT_ALARM 은 시계·달력 앱 전용이므로 SCHEDULE_EXACT_ALARM 사용.
    -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!--
        ════════════════════════════════════════════════════════
         APPLICATION
        ════════════════════════════════════════════════════════
    -->
    <application
        android:name=".DopamineCatApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@android:drawable/sym_def_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.DopamineCat"
        tools:targetApi="34">

        <!-- ── Main Activity ──────────────────────────────────────────── -->
        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.DopamineCat.SplashScreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            ── UsageTrackingService ──────────────────────────────────────
            5분 주기로 UsageStatsManager 를 폴링하는 포그라운드 서비스.
            foregroundServiceType = dataSync: API 34 필수 선언.
            exported=false: 외부 앱에서 직접 시작 불가.
        -->
        <service
            android:name=".data.service.UsageTrackingService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!--
            ── BootReceiver ──────────────────────────────────────────────
            BOOT_COMPLETED: 재부팅 후 서비스와 WorkManager 재시작.
            MY_PACKAGE_REPLACED: 앱 업데이트 후 동일 처리.
        -->
        <receiver
            android:name=".data.receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!--
            ── CatWidgetReceiver (Glance) ────────────────────────────────
            GlanceAppWidgetReceiver 를 상속해 Compose 로 위젯 렌더링.
            cat_widget_info.xml 에서 위젯 크기·업데이트 주기 선언.
        -->
        <receiver
            android:name=".presentation.widget.CatWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <!-- 서비스·Worker 가 고양이 상태 변경 후 위젯을 즉시 갱신하기 위한 커스텀 액션 -->
                <action android:name="com.dopaminecat.ACTION_UPDATE_WIDGET" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/cat_widget_info" />
        </receiver>

        <!--
            ── WorkManager 커스텀 초기화 ─────────────────────────────────
            Hilt 와 WorkManager 를 통합하려면 기본 자동 초기화를 제거하고
            DopamineCatApplication 에서 HiltWorkerFactory 를 수동 등록해야 한다.
            이 설정 없이는 @HiltWorker 내부의 @Inject 가 동작하지 않는다.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
